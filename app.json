{
  "expo": {
    "name": "band-manager-pro",
    "slug": "band-manager-pro",
    "scheme": "bandmanagerpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bandmanagerpro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bandmanagerpro",
      "adaptiveIcon": {
        "backgroundColor": "#1E4157",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13700eb6-8fb9-4568-9e26-1ca1e0ca69de"
      }
    },
    "owner": "remo.schlosser"
  }
}
